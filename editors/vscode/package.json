{
  "name": "elps-lang",
  "displayName": "ELPS Lisp",
  "description": "ELPS — embedded Lisp interpreter for Go. Syntax highlighting, language server, and debugger.",
  "version": "0.0.0",
  "publisher": "LutherSystems",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/luthersystems/elps"
  },
  "homepage": "https://github.com/luthersystems/elps",
  "bugs": {
    "url": "https://github.com/luthersystems/elps/issues"
  },
  "qna": "https://github.com/luthersystems/elps/issues",
  "icon": "images/icon.png",
  "markdown": "github",
  "keywords": [
    "lisp",
    "elps",
    "lsp",
    "debugger",
    "s-expression",
    "interpreter",
    "language-server"
  ],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Linters",
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:elps"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "esbuild extension.js --bundle --outdir=dist --platform=node --external:vscode --format=cjs --minify",
    "package": "npm run build && vsce package --allow-missing-repository",
    "test": "vscode-tmgrammar-test -g syntaxes/elps.tmLanguage.json 'test/grammar/*.lisp'"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.25.12",
    "vscode-tmgrammar-test": "^0.1.3"
  },
  "contributes": {
    "languages": [
      {
        "id": "elps",
        "aliases": [
          "ELPS",
          "elps"
        ],
        "extensions": [
          ".lisp"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "elps",
        "scopeName": "source.elps",
        "path": "./syntaxes/elps.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "ELPS",
      "properties": {
        "elps.path": {
          "type": "string",
          "default": "elps",
          "description": "Path to the elps binary"
        },
        "elps.lsp.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the ELPS language server"
        },
        "elps.lsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication with the ELPS language server"
        }
      }
    },
    "debuggers": [
      {
        "type": "elps",
        "label": "ELPS Debug",
        "languages": [
          "elps"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .lisp file to debug",
                "default": "${file}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Pause before the first expression",
                "default": true
              },
              "rootDir": {
                "type": "string",
                "description": "Source root directory for file resolution",
                "default": "${workspaceFolder}"
              },
              "elpsPath": {
                "type": "string",
                "description": "Path to the elps binary (overrides elps.path setting)",
                "default": ""
              }
            }
          },
          "attach": {
            "properties": {
              "host": {
                "type": "string",
                "description": "Host of the running DAP server",
                "default": "localhost"
              },
              "port": {
                "type": "number",
                "description": "Port of the running DAP server",
                "default": 4711
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "elps",
            "request": "launch",
            "name": "Debug ELPS",
            "program": "${file}",
            "stopOnEntry": true
          },
          {
            "type": "elps",
            "request": "attach",
            "name": "Attach to ELPS",
            "host": "localhost",
            "port": 4711
          }
        ],
        "configurationSnippets": [
          {
            "label": "ELPS: Debug File",
            "description": "Debug the current ELPS file",
            "body": {
              "type": "elps",
              "request": "launch",
              "name": "Debug ELPS",
              "program": "^\"\\${file}\"",
              "stopOnEntry": true
            }
          },
          {
            "label": "ELPS: Attach to Server",
            "description": "Attach to a running ELPS DAP server",
            "body": {
              "type": "elps",
              "request": "attach",
              "name": "Attach to ELPS",
              "host": "localhost",
              "port": 4711
            }
          }
        ]
      }
    ]
  }
}
